{
  "manifest_version": 3,
  "minimum_chrome_version": "120",
  "name": "WinSpeedBall",
  "version": "3.1.0",
  "description": "Browser extension for video speed, volume, screenshot OCR, and DeepSeek study assistance.",
  "permissions": ["scripting", "storage", "alarms", "offscreen"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["shadow_hook.js"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*/*"],
      "js": ["content_script.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-blue-16.png",
      "32": "icons/icon-blue-32.png",
      "48": "icons/icon-blue-48.png",
      "128": "icons/icon-blue-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "WinSpeedBall"
  },
  "icons": {
    "16": "icons/icon-blue-16.png",
    "32": "icons/icon-blue-32.png",
    "48": "icons/icon-blue-48.png",
    "128": "icons/icon-blue-128.png"
  },
  "commands": {
    "region-capture": {
      "suggested_key": { "default": "Alt+O" },
      "description": "\u542f\u52a8\u533a\u57df OCR \u6846\u9009"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-inline' 'unsafe-eval'; object-src 'none'"
  },
  "sandbox": {
    "pages": ["script_workspace.html"]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/tesseract/tesseract.min.js",
        "vendor/tesseract/worker.min.js",
        "vendor/tesseract/tesseract-core.wasm.js",
        "vendor/tesseract/*.traineddata.gz"
      ],
      "matches": ["*://*/*"]
    }
  ]
}
