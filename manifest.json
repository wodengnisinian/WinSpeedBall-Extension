{
  "manifest_version": 3,
  "minimum_chrome_version": "135",
  "name": "WinSpeedBall",
  "version": "3.4.0",
  "description": "AI study assistant with video tools, OCR, configurable AI, local accounts, and usage disclosure.",
  "permissions": ["activeTab", "scripting", "storage", "alarms", "offscreen", "userScripts"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-blue-16.png",
      "32": "icons/icon-blue-32.png",
      "48": "icons/icon-blue-48.png",
      "128": "icons/icon-blue-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "WinSpeedBall"
  },
  "icons": {
    "16": "icons/icon-blue-16.png",
    "32": "icons/icon-blue-32.png",
    "48": "icons/icon-blue-48.png",
    "128": "icons/icon-blue-128.png"
  },
  "commands": {
    "region-capture": {
      "suggested_key": { "default": "Alt+O" },
      "description": "\u542f\u52a8\u533a\u57df OCR \u6846\u9009"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-inline' 'unsafe-eval'; object-src 'none'"
  },
  "sandbox": {
    "pages": ["script_workspace.html"]
  }
}
